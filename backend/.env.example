# Backend server port for local development.
PORT=

# Frontend origin allowed to access the API with credentials.
CLIENT_ORIGIN=

# Runtime environment name such as development, test, or production.
NODE_ENV=

# MySQL host name or IP address.
DB_HOST=

# MySQL port number.
DB_PORT=

# Name of the MySQL database used by the backend.
DB_NAME=

# MySQL username with access to the target database.
DB_USER=

# MySQL password for the database user.
DB_PASSWORD=

# Set to true or false. Keep false when using migrations.
DB_SYNCHRONIZE=

# Secret used to sign JWT tokens. Use a long random value.
JWT_SECRET=

# Access token lifetime, for example a short duration string.
JWT_EXPIRES_IN=

# Refresh token lifetime, usually longer than the access token.
JWT_REFRESH_EXPIRES_IN=
